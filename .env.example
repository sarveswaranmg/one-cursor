# Pusher (Channels) — create a free app at https://dashboard.pusher.com
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Upstash Redis — add from the Vercel dashboard: Storage tab -> Upstash -> Redis.
# Vercel injects KV_REST_API_URL / KV_REST_API_TOKEN automatically when linked;
# these two are only needed if you provision Upstash directly instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
